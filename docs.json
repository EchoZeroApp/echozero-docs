{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "EchoZero",
  "colors": {
    "primary": "#FF5508",
    "light": "#FF7733",
    "dark": "#CC4406"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "api": {
    "openapi": "https://mcp.echozero.app/api/docs-json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "typescript", "go"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Developers",
        "href": "https://echozero.app/developers"
      },
      {
        "label": "Dev Portal",
        "href": "https://devportal.echozero.app"
      },
      {
        "label": "Support",
        "href": "/support"
      },
      {
        "label": "Changelog",
        "href": "/changelog"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Dev Portal",
      "href": "https://devportal.echozero.app"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "concepts/how-it-works",
              "tutorials/first-agent",
              "quickstart"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/objects",
              "guides/authentication",
              "guides/earnings"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/signal-envelope",
              "guides/signal-grammar",
              "guides/websocket-gateway",
              "guides/webhook-security",
              "guides/signature-test-vectors",
              "guides/sandbox",
              "guides/agent-lifecycle",
              "guides/signal-groups",
              "guides/mcp",
              "mcp/tools",
              "mcp/resources",
              "guides/oauth",
              "guides/api-keys-hmac",
              "guides/conventions",
              "guides/error-codes",
              "guides/versioning"
            ]
          },
          {
            "group": "Recipes",
            "pages": [
              "recipes/telegram-relay",
              "recipes/tradingview-alerts",
              "recipes/hyperliquid-perp",
              "recipes/lifecycle-python"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              {
                "group": "Client libraries",
                "tag": "Coming soon",
                "pages": ["guides/sdk"]
              }
            ]
          },
          {
            "group": "Legal & support",
            "pages": ["support", "terms", "changelog"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://mcp.echozero.app/api/docs-json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "OpenAPI spec",
          "href": "https://mcp.echozero.app/api/docs-json",
          "icon": "file-code"
        },
        {
          "anchor": "MCP Server",
          "href": "/guides/mcp",
          "icon": "server"
        },
        {
          "anchor": "GitHub SDK",
          "href": "https://github.com/EchoZeroApp/echozero-sdk",
          "icon": "github"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/EchoZeroApp/echozero-sdk"
    },
    "links": [
      {
        "header": "Support",
        "items": [
          {
            "label": "developers@echozero.app",
            "href": "mailto:developers@echozero.app"
          },
          {
            "label": "Status",
            "href": "https://status.echozero.app"
          }
        ]
      },
      {
        "header": "Resources",
        "items": [
          {
            "label": "OpenAPI JSON",
            "href": "https://mcp.echozero.app/api/docs-json"
          },
          {
            "label": "Developer terms",
            "href": "/terms"
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "cursor"]
  }
}
